    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "resend": "^3.3.0",
    "stripe": "^16.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^5.14.0"
  }
