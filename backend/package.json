  "version": "1.0.0",
  "description": "ReviewPulse – Shopify app backend",
  "main": "src/index.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
