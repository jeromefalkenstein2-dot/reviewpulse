NODE_ENV=production
PORT=3001

# Database provider: "postgresql" for production, "sqlite" for local dev
DB_PROVIDER=postgresql

# Shopify App Credentials (from partners.shopify.com)
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_orders,read_customers

# App URLs
HOST=https://your-backend.railway.app
FRONTEND_URL=https://your-frontend.vercel.app

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/reviewpulse

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_TRIAL_DAYS=14

# Security
SESSION_SECRET=a_very_long_random_secret_string_here
